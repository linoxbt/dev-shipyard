# QIE network config (public — safe to ship to the browser). Defaults match
# docs.qie.digital, so these are optional overrides.
VITE_QIE_TESTNET_RPC=https://rpc1testnet.qie.digital/
VITE_QIE_TESTNET_EXPLORER=https://testnet.qie.digital
VITE_QIE_TESTNET_CHAIN_ID=1983

VITE_QIE_MAINNET_RPC=https://rpc1mainnet.qie.digital/
VITE_QIE_MAINNET_EXPLORER=https://mainnet.qie.digital
VITE_QIE_MAINNET_CHAIN_ID=1990

# QIE DEX swap URL (the "get QIE for gas" link)
VITE_QIE_DEX_URL=https://www.swap.dex.qie.digital/swap

# DevStation registry addresses — per network, filled after running
# scripts/deploy.ts on each chain. The legacy VITE_*_ADDRESS (no suffix) is
# still read as the testnet fallback.
VITE_PROJECT_REGISTRY_ADDRESS_TESTNET=
VITE_PROJECT_REGISTRY_ADDRESS_MAINNET=
VITE_LABEL_REGISTRY_ADDRESS_TESTNET=
VITE_LABEL_REGISTRY_ADDRESS_MAINNET=

# QIE QUSDC stablecoin address — obtain from docs.stable.qie.digital / explorer.
# When unset, the QUSDC balance line is hidden.
VITE_QUSDC_ADDRESS=

# Server-only: private key for scripts/deploy.ts. NEVER commit. Goes in .env.local
# PRIVATE_KEY=0x...

# AI assistant (Code with AI). Two providers; the user can also switch and paste
# a key in the panel's settings at runtime. Keys here ship to the browser, so use
# a personal key, not a shared production one.
#
# Which provider to default to: "anthropic" or "openai". If unset, defaults to
# whichever has a key below (tie-break: anthropic).
VITE_AI_PROVIDER=anthropic
#
# Anthropic (native Claude Messages API):
VITE_ANTHROPIC_API_KEY=
VITE_ANTHROPIC_MODEL=claude-opus-4-8
# VITE_ANTHROPIC_ENDPOINT=https://api.anthropic.com   # override for a proxy
#
# OpenAI-compatible (/chat/completions):
VITE_AI_ENDPOINT=
VITE_AI_API_KEY=
VITE_AI_MODEL=gpt-4o-mini

# --- Server proxy: provide a default AI key for all users (recommended) ---
# Set VITE_AI_PROXY=true so the browser calls this app's /api/ai route instead
# of the provider directly. The keys below have NO VITE_ prefix, so Vite never
# inlines them into the client bundle — they stay server-side. In the app's AI
# settings, users then choose "Provided default" (this key) or "Use my own key".
# VITE_AI_PROXY=true
#
# EASIEST: one OpenRouter key powers the default. Set this in the Netlify/Vercel
# dashboard (server-only, NOT VITE_-prefixed) plus VITE_AI_PROXY=true:
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_MODEL=openai/gpt-4o-mini   # optional; any OpenRouter model id
#
# Other server-only options (NEVER VITE_-prefixed):
# AI_PROVIDER=anthropic            # or "openai"; defaults to whichever key is set
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_ENDPOINT=https://api.anthropic.com
# OPENAI_ENDPOINT=https://api.openai.com/v1/chat/completions
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
